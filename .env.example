# ===== Model =====
ARK_API_KEY=your_ark_api_key
MODEL=your_model_name
# 复杂度规划，以及 Step-back / HyDE 单选重写使用低延迟模型。
FAST_MODEL=your_fast_model_name
# 证据相关性、可回答性、歧义和路由评判使用独立的高能力模型。
GRADE_MODEL=your_grade_model_name
BASE_URL=https://your-llm-endpoint/v1

# ===== 本地稠密向量（langchain_huggingface，默认 BAAI/bge-m3）=====
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
DENSE_EMBEDDING_DIM=1024
# Hugging Face 国内镜像源加速（解决直连 huggingface.co 加载本地嵌入模型卡死的问题）
HF_ENDPOINT=https://hf-mirror.com

# ===== Rerank (可选，不配则自动降级) =====
RERANK_MODEL=your_rerank_model
RERANK_BINDING_HOST=https://your-rerank-host
RERANK_API_KEY=your_rerank_api_key
# Rerank 上游最大等待时间；占位符配置会被自动识别为未启用。
RERANK_TIMEOUT_SECONDS=5

# ===== 检索候选池 & Auto-merging =====
# 精排后返回给 Agent 的片段数
RETRIEVAL_TOP_K=8
# Milvus 叶子层召回候选数：设 RETRIEVAL_CANDIDATE_K 时优先使用（且 >= top_k）
# 未设 K 时：candidate_k = max(top_k * RETRIEVAL_CANDIDATE_MULTIPLIER, top_k)
RETRIEVAL_CANDIDATE_K=30
RETRIEVAL_CANDIDATE_MULTIPLIER=3
AUTO_MERGE_ENABLED=true
AUTO_MERGE_THRESHOLD=2
LEAF_RETRIEVE_LEVEL=3
# 精排后进入 Agent 的最低分（默认 0，上线后按数据标定）
RERANK_MIN_SCORE=0.0

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection
# 单次 RPC 超时（秒）；连接按请求创建，不长期占用 gRPC channel
MILVUS_TIMEOUT=30

# ===== Database / Cache =====
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/langchain_app
REDIS_URL=redis://127.0.0.1:6379/0

# ===== Auth =====
JWT_SECRET_KEY=replace-with-strong-random-secret
ADMIN_INVITE_CODE=supermew-admin-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000

# ===== Tools（可选）=====
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=your_amap_api_key
